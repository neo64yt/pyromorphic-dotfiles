{
    "name": "bottombar",
    "layer": "top",
    "position": "bottom",
    "height": 30,
    "exclusive": true,
    "on-sigusr1": "noop",
    "on-sigusr2": "noop",
    "passthrough": false,
    "reload_style_on_change": true,
    "modules-center": ["wlr/taskbar"],
    "modules-right": ["idle_inhibitor", "tray"],

    "wlr/taskbar": {
        "format": "{icon}",
        "on-click": "activate",
        "on-click-middle": "minimize",
        "on-click-right": "close",
        "icon-size": 18
    },

    "tray": {
        "icon-size": 15,
        "spacing": 5,
        "show-passive-items": true
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "󰈈",
            "deactivated": "󰈉"
        }
    }


}

