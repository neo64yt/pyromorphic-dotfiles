{
    "name": "topbar",
    "layer": "top", 
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 30, // Waybar height
    //"mode": "dock",
    // "width": 120, // Waybar width
    // Choose the order of the modules
    "on-sigusr1": "noop",
    "on-sigusr2": "noop",
    "reload_style_on_change": true,
    "modules-left": [ "custom/quickmenu", "wlr/taskbar" ],
    "modules-center": ["ext/workspaces", "clock"],
    "modules-right": ["wireplumber", "backlight", "battery", "tray" ],
    // Modules configuration
    "wlr/taskbar": {
        "format": "{icon}",
        "on-click": "activate",
        "on-click-middle": "minimize",
        "on-click-right": "close",
        "icon-size": 18
    },

    "custom/quickmenu": {
        "on-click": "prerun-quickmenu",
        "format": "¾░╗Ç",
        "tooltip-format": "Quick access"
    },

    "custom/sb-toggle": {
        "on-click": "killall -SIGUSR1 waybar",
        "format": "¾░ø¢",
        "tooltip-format": "Toggle sidebar"
    },

    "ext/workspaces": {
        "format": "",
        "on-click": "activate",
        "sort-by-id": true,
        "active-only": true
    },

    "clock": {
        "timezone": "Asia/Kuala_Lumpur",
        "format": "¾▒æì {:%H:%M}",
        "format-alt": "¾░©ÿ {:%a %Y-%m-%d}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "mode": "month",
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }    
        },
        "actions": {
                "on-scroll-up": "shift_up",
                "on-scroll-down": "shift_down"
        }
    },

    "cpu": {
        "format": "¾░ÿÜ {usage}%"
    },

    "memory": {
        "format": "¾░ìø {}%"
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{icon} {percent}%",
        "tooltip-format": "{icon} {percent}%",
        "states": [0,50],
        "format-icons": ["¾░âÜ", "¾░âá"]
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-icons": {
            "default": ["¾░ü║", "¾░ü╝", "¾░ü¥", "¾░éÇ", "¾░ü╣"],
            "charging": ["¾▒Éï¾░ü║", "¾▒Éï¾░ü╝", "¾▒Éï¾░ü¥", "¾▒Éï¾░éÇ", "¾▒Éï¾░ü╣"]
        }
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "network": {
        // "interface": "wlp2s0", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%) ´ç½",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr} ´âü",
        "format-disconnected": "Disconnected ÔÜá",
        "interval" : 7
    },
    "wireplumber": {
        "format": "{icon} {volume}%",
        "tooltip-format": "{icon} {volume}%",
        "format-muted": "¾░Øƒ [MUTED]",
        "format-icons": ["¾░ûÇ", "¾░ò¥"],
        "on-click": "wpctl set-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol"
    },

    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        "format-icons": ["¾░öÅ"], 
        "format-critical": "{icon} {temperatureC}┬░C",
        "format": "{icon} {temperatureC}┬░C",
        "tooltip-format": "{temperatureC}┬░C"
    },

    "tray": {
        "icon-size": 15,
        "spacing": 3,
        "show-passive-items": true
    }

}

