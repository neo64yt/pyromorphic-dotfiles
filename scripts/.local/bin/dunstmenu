# Managing sessions

# Defaults
prompt="Dunst Action Handler:"
lines=5

if [ -z "$WAYLAND_DISPLAY" ]; then
    ROFI_EXTRA_OPTS="-dpi 0 -theme dmenu-x11"
else
    ROFI_EXTRA_OPTS=""
fi

menu_handler() {
    rofi -dmenu -p "$prompt" -l $lines $ROFI_EXTRA_OPTS
}

menu_handler



# vim: ft=sh
