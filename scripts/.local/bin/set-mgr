# Settings manager

# Defaults
prompt="¾░ó╗ Settings for $(whoami):"
lines=9

# For settings that need config file editing
config_edit="$TERMINAL -e $EDITOR"

# List of choices (function)
list_choices(){
	cat << EOF
¾░Åś GTK
¾░Åś Kvantum
¾░Åś Qt5
¾░Åś Qt6
¾░▓Ø Network
¾░£ć Printer
¾░ī¦ Autostart
¾░Ż¢ Dconf
¾░Å¢ Flatpak permissions
EOF
}

if [ -z "$WAYLAND_DISPLAY" ]; then
    ROFI_EXTRA_OPTS="-dpi 0 -theme dmenu-x11"
else
    ROFI_EXTRA_OPTS=""
fi

menu_handler() {
    rofi -dmenu -p "$prompt" -l $lines $ROFI_EXTRA_OPTS
}

# Command
choice=$(list_choices | menu_handler)

case "$choice" in
    "¾░Åś GTK") $LOOKS_GTK ;;
    "¾░Åś Kvantum") $KVANTUM_MGR ;;
    "¾░Åś Qt5") $LOOKS_QT5 ;;
    "¾░Åś Qt6") $LOOKS_QT6 ;;
  	"¾░▓Ø Network") $NM_EDITOR ;;
  	"¾░£ć Printer") $PRINT ;;
  	"¾░ī¦ Autostart") $config_edit $AUTOSTART ;;
	"¾░Ż¢ Dconf") $DCONF_EDITOR ;;
	"¾░Å¢ Flatpak permissions") $FLATSEAL ;;
esac



# vim: ft=sh
