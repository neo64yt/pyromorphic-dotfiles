#!/bin/sh

################################
#                              #
#          QUICK MENU          #
#                              #
#      pyromorphic-desktop     #
#                              #
################################


# Defaults
prompt="َ±چ• Quick access:"
lines=8

# List of choices (function)
list_choices(){
	cat << EOF
َ°€» Applications
َ°†چ Run
َ°گ¦ System
َ°±¨ Emojis
َ°¢» Settings
EOF
}

if [ -z "$WAYLAND_DISPLAY" ]; then
    menu_handler(){ 
        dmenu -l $lines -p "$prompt" 
    }
else
    menu_handler(){ 
        rofi -dmenu -p "$prompt" -l $lines 
    }
fi

choice=$(list_choices | menu_handler)

case "$choice" in
  	"َ°€» Applications") desktopmenu ;;
  	"َ°†چ Run") cmdrun ;;
  	"َ°گ¦ System") sessionmgr ;;
  	"َ°±¨ Emojis") emojisel ;;
  	"َ°¢» Settings") set-mgr ;;
	*) exit 1 ;;
esac



# vim: ft=sh
