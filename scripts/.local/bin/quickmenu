#!/bin/sh

################################
#                              #
#          QUICK MENU          #
#                              #
#      pyromorphic-desktop     #
#                              #
################################


# Defaults
prompt="¾▒ıò Quick access:"
lines=8

# List of choices (function)
list_choices(){
	cat << EOF
¾░Ç╗ Applications
¾░åı Run
¾░ÉĞ System
¾░▒¿ Emojis
¾▒İŞ Clipboard
¾░¬Ü Calculator
¾▒ò┤ Passwords
¾░ó╗ Settings
EOF
}

if [ -z "$WAYLAND_DISPLAY" ]; then
    menu_handler(){ 
        dmenu -l $lines -p "$prompt" 
    }
else
    menu_handler(){ 
        rofi -dmenu -p "$prompt" -l $lines 
    }
fi

choice=$(list_choices | menu_handler)

case "$choice" in
  	"¾░Ç╗ Applications") desktopmenu ;;
  	"¾░åı Run") cmdrun ;;
  	"¾░ÉĞ System") sessionmgr ;;
  	"¾░▒¿ Emojis") rofi -show emoji -modi emoji ;;
    "¾▒İŞ Clipboard") rofi -modi clipboard:${XDG_DATA_HOME}/rofi-modes/cliphist-rofi-img -show clipboard -show-icons ;;
    "¾░¬Ü Calculator") rofi -show calc -modi calc ;;
    "¾▒ò┤ Passwords") rofi-rbw ;;
  	"¾░ó╗ Settings") set-mgr ;;
	*) exit 1 ;;
esac



# vim: ft=sh
