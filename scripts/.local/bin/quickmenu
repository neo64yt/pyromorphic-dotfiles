#!/bin/sh

################################
#                              #
#          QUICK MENU          #
#                              #
#      pyromorphic-desktop     #
#                              #
################################

set -x

# Defaults
prompt="َ±چ• Quick access:"
lines=8

# List of choices (function)
list_choices(){
	cat << EOF
َ°€» Applications
َ°†چ Run
َ°گ¦ System
َ°±¨ Emojis
َ±•´ Passwords
َ°¢» Settings
EOF
}

if [ -z "$WAYLAND_DISPLAY" ]; then
    ROFI_EXTRA_OPTS="-dpi 0 -theme dmenu-x11" 
else
    ROFI_EXTRA_OPTS="" 
fi

menu_handler() {
    rofi -dmenu -p "$prompt" -l $lines $ROFI_EXTRA_OPTS
}

choice=$(list_choices | menu_handler)

case "$choice" in
  	"َ°€» Applications") desktopmenu ;;
  	"َ°†چ Run") cmdrun ;;
  	"َ°گ¦ System") sessionmgr ;;
  	"َ°±¨ Emojis") emojisel ;;
    "َ±•´ Passwords") rofi-rbw-wrap ;;
  	"َ°¢» Settings") set-mgr ;;
	*) exit 1 ;;
esac



# vim: ft=sh
